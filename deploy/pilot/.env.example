# Copy to .env and fill in real values before `docker compose up -d`.

# Public hostname Caddy should obtain a certificate for.
DIBBLE_DOMAIN=pilot.example.ca

# --- Production guards (GET /ready validates these) ------------------------
DIBBLE_AUTH_ENABLED=true
DIBBLE_AUTH_TOKEN_SECRET=change-me-to-a-long-random-string
DIBBLE_LLM_ALLOW_MOCK_FALLBACK=false

# --- LLM provider (prefer a zero-retention API configuration) --------------
DIBBLE_LLM_API_BASE=https://api.openai.com/v1
DIBBLE_LLM_API_KEY=
DIBBLE_LLM_MODEL=

# Optional secondary provider: generation failover and, when
# DIBBLE_MODERATION_LLM_ENABLED=true, the LLM safety check for learner drafts.
DIBBLE_LLM_SECONDARY_API_BASE=
DIBBLE_LLM_SECONDARY_API_KEY=
DIBBLE_LLM_SECONDARY_MODEL=
DIBBLE_MODERATION_LLM_ENABLED=false

# Optional off-host backup target for the nightly snapshot job.
# DIBBLE_BACKUP_REMOTE=user@backup-host:/backups/dibble
