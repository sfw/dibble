# Copy this file to deploy/household/.env before first run.

DIBBLE_AUTH_ENABLED=true
DIBBLE_AUTH_TOKEN_SECRET=replace-with-a-long-random-secret
DIBBLE_TELEMETRY_LEVEL=normal

# Primary OpenAI-compatible LLM provider.
DIBBLE_LLM_API_BASE=https://api.openai.com/v1
DIBBLE_LLM_API_KEY=
DIBBLE_LLM_MODEL=gpt-4o
DIBBLE_LLM_ALLOW_MOCK_FALLBACK=true
DIBBLE_LLM_TIMEOUT_SECONDS=20

# Optional embedding provider. If omitted, Dibble falls back to the LLM key
# or to local lexical retrieval when no embedding key is configured.
DIBBLE_EMBEDDING_API_BASE=https://api.openai.com/v1
DIBBLE_EMBEDDING_API_KEY=
DIBBLE_EMBEDDING_MODEL=text-embedding-3-small

# Pilot default: remote cloud-library reads/publishes stay off until explicitly
# enabled by an operator. Local curriculum-shaped reuse remains active.
DIBBLE_CLOUD_LIBRARY_ENABLED=false
DIBBLE_CLOUD_LIBRARY_ENDPOINT=
DIBBLE_CLOUD_LIBRARY_API_KEY=
